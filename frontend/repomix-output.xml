                      {task.description && (
                        <p style={{ fontSize: 12, color: T.colors.text.muted, margin: '0 0 6px', lineHeight: 1.5, overflow: 'hidden', display: '-webkit-box', WebkitLineClamp: 1, WebkitBoxOrient: 'vertical' }}>
                          {task.description}
                        </p>
                      )}
