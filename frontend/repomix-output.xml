              style={{ flex: 1, background: T.gradients.brand, color: '#fff', opacity: busy || !form.title.trim() ? 0.65 : 1, boxShadow: form.title.trim() ? '0 4px 14px rgba(99,102,241,0.3)' : 'none' }}>
              {busy ? 'Creating…' : '✓ Create Task'}
            </button>
