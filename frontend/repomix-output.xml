        <span className="an-stat-change" style={{
          background: up ? T.colors.success.bg : T.colors.danger.bg,
          color: up ? T.colors.success.text : T.colors.danger.text,
        }}>
          {up ? '↑' : '↓'} {change}
        </span>
      </div>
    </div>
  )
}

