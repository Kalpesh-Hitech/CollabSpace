  --font-display : 'Outfit', sans-serif;
  --font-mono    : 'Fira Code', monospace;

  --color-primary    : #6366f1;
  --color-primary-600: #4f46e5;
  --color-primary-400: #818cf8;
  --color-accent     : #7c3aed;
  --color-teal       : #14b8a6;

  --bg-page    : #0f1117;
  --bg-sidebar : #13151f;
  --bg-card    : #1a1d2e;
  --bg-elevated: #1f2235;
  --bg-hover   : #252840;
  --bg-border  : #2d3050;

  --text-primary  : #f8fafc;
  --text-secondary: #94a3b8;
  --text-muted    : #475569;

  --header-h     : 60px;
  --sidebar-w    : 256px;
  --sidebar-coll : 64px;

  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;
  --radius-xl: 18px;

  --shadow-glow : 0 0 20px rgba(99,102,241,0.3);
  --shadow-glows: 0 0 12px rgba(99,102,241,0.2);
  --grad-brand  : linear-gradient(135deg, #6366f1 0%, #7c3aed 100%);
}

/* ── Base Reset ───────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }

html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-body);
  background: var(--bg-page);
  color: var(--text-primary);
  line-height: 1.6;
  overflow-x: hidden;
}

/* ── HIDE ALL SCROLLBARS (Rule 3) ────────────────────────── */
* { scrollbar-width: none; -ms-overflow-style: none; }
*::-webkit-scrollbar { display: none; }

/* ── Sidebar scroll area: overflow-y but no scrollbar ────── */
.sidebar-scroll { overflow-y: auto; overflow-x: hidden; }

/* ── Animations ───────────────────────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes pulse-glow {
  0%,100% { box-shadow: 0 0 16px rgba(99,102,241,0.35); }
  50%     { box-shadow: 0 0 28px rgba(99,102,241,0.6); }
}
@keyframes status-ping {
  0%,100% { opacity: 1; }
  50%     { opacity: 0.4; }
}
@keyframes slide-in {
  from { transform: translateX(-100%); opacity: 0; }
  to   { transform: translateX(0);     opacity: 1; }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

.anim-fade-up   { animation: fadeUp  0.35s cubic-bezier(.4,0,.2,1) both; }
.anim-fade-in   { animation: fadeIn  0.25s ease both; }
.anim-slide-in  { animation: slide-in 0.3s cubic-bezier(.4,0,.2,1) both; }
.anim-logo-glow { animation: pulse-glow 3s ease-in-out infinite; }
.anim-status    { animation: status-ping 2.5s ease-in-out infinite; }

.delay-1 { animation-delay: 0.08s; }
.delay-2 { animation-delay: 0.16s; }
.delay-3 { animation-delay: 0.24s; }
.delay-4 { animation-delay: 0.32s; }

/* ── Tooltip for collapsed sidebar ───────────────────────── */
.tooltip-wrap { position: relative; }
.tooltip-wrap .tooltip-text {
  position: absolute;
  left: calc(100% + 10px);
  top: 50%;
  transform: translateY(-50%);
  background: var(--bg-elevated);
  border: 1px solid var(--bg-border);
  color: var(--text-primary);
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 500;
  padding: 5px 10px;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  pointer-events: none;
  opacity: 0;
  z-index: 9999;
  box-shadow: 0 4px 16px rgba(0,0,0,0.4);
  transition: opacity 0.15s ease;
}
.tooltip-wrap:hover .tooltip-text { opacity: 1; }

/* ── Glass morphism ───────────────────────────────────────── */
.glass {
  background: rgba(19, 21, 31, 0.8);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}

/* ── Focus ring (accessibility) ──────────────────────────── */
*:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
  border-radius: var(--radius-sm);
}

/* ── Progress bar fill animation ─────────────────────────── */
.progress-fill { transition: width 0.8s cubic-bezier(.4,0,.2,1); }
</file>

